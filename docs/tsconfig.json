{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./src/components/shared/*"],
      "@landing/*": ["./src/components/landing/*"],
      "@playground/*": ["./src/components/playground/*"],
      "@components/*": ["./src/components/*"],
      "@util/*s": ["./src/utils/*"],
      "@pages/*": ["./src/pages/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@config/*": ["./src/config/*"],
      "@data/*": ["./src/data/*"],
      "@composables/*": ["./src/composables/*"],
      "@utils/*": ["./src/utils/*"],

      "@supermousejs/*": ["../packages/*/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": []
}
