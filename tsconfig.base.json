{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases for monorepo packages */
    "baseUrl": ".",
    "paths": {
      "@supermousejs/core": ["./packages/core/src"],
      "@supermousejs/utils": ["./packages/utils/src"],
      "@supermousejs/dot": ["./packages/dot/src"],
      "@supermousejs/ring": ["./packages/ring/src"],
      "@supermousejs/text": ["./packages/text/src"],
      "@supermousejs/image": ["./packages/image/src"],
      "@supermousejs/magnetic": ["./packages/magnetic/src"],
      "@supermousejs/pointer": ["./packages/pointer/src"],
      "@supermousejs/icon": ["./packages/icon/src"],
      "@supermousejs/states": ["./packages/states/src"],
      "@supermousejs/stick": ["./packages/stick/src"],
      "@supermousejs/vue": ["./packages/vue/src"],
      "@supermousejs/react": ["./packages/react/src"],
      "@supermousejs/trail": ["./packages/trail/src"],
      "@supermousejs/labs": ["./packages/labs/src"],
      "@supermousejs/zoetrope": ["./packages/zoetrope/src"]
    }
  }
}
